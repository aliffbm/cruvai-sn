# ============================================================
# Cruvai ServiceNow Developer — Environment Configuration
# ============================================================
# Copy to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cruvai:cruvai@localhost:5432/cruvai_sn
DATABASE_URL_SYNC=postgresql://cruvai:cruvai@localhost:5432/cruvai_sn
POSTGRES_USER=cruvai
POSTGRES_PASSWORD=cruvai
POSTGRES_DB=cruvai_sn

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
SECRET_KEY=change-me-to-a-random-64-char-string
CRUVAI_ENCRYPTION_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI / LLM ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# --- ServiceNow (for development/testing) ---
# SN_INSTANCE_URL=https://dev12345.service-now.com
# SN_USERNAME=admin
# SN_PASSWORD=

# --- OpenClaw (Phase 2) ---
# OPENCLAW_ENABLED=false
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# --- Application ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
